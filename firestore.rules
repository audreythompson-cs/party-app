rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.active == true;
    }

    // Admin access is provisioned manually in the Firebase Console.
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
      allow write: if false;
    }

    // System Config: Anyone authenticated can read passcodes, only admins can write
    match /config/system {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Game State: Anyone authenticated can read/write (needed for players to buzz in)
    match /config/gameState {
      allow read, write: if request.auth != null;
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if request.auth != null;
      // Allow creation/modification of profile
      allow create: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (resource.data.get('isPlaceholder', false) == true || isAdmin());
    }

    // Point history: Users can read all, any authenticated user can create point logs (needed for TV/Admin point changes)
    match /pointHistory/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(resource.data.userId)) &&
         get(/databases/$(database)/documents/users/$(resource.data.userId)).data.get('isPlaceholder', false) == true) ||
        isAdmin()
      );
    }

    // Goals collection rules
    match /goals/{goalId} {
      allow read: if request.auth != null;
      allow create, delete: if isAdmin();
      allow update: if request.auth != null && (isAdmin() || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['assignedTo']));
    }

    // Jeopardy collection rules
    match /jeopardy/{categoryId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Teams collection rules
    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // User goals checklist
    match /userGoals/{userGoalId} {
      allow read: if request.auth != null;
      // Users can submit/update their own checklist status
      allow create, update: if request.auth != null && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        (exists(/databases/$(database)/documents/users/$(resource.data.userId)) &&
         get(/databases/$(database)/documents/users/$(resource.data.userId)).data.get('isPlaceholder', false) == true) ||
        isAdmin()
      );
    }
  }
}
